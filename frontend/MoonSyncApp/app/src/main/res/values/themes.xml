<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <!-- Splash theme (used ONLY at startup) -->
    <style name="Theme.MoonSyncApp.Splash" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
    </style>

    <!-- Main app theme -->
    <style name="Theme.MoonSyncApp" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
    </style>

</resources>